%6.封面页生成
\newcommand{\makecover}{
    \begin{titlepage}
        \thispagestyle{empty}
        \begin{tikzpicture}[remember picture, overlay]
            \begin{scope}
                \clip (current page.north west) rectangle ([yshift=-0.69\paperheight]current page.north east);
                \node[anchor=north, inner sep=0pt] at (current page.north) {
                    \includegraphics[width=\paperwidth]{\lcc@sectionbg}
                };
            \end{scope}
            \fill[white, path fading=north] 
                ([yshift=-0.67\paperheight]current page.north west) 
                rectangle 
                ([yshift=-0.67\paperheight+4.5cm]current page.north east);
            \fill[white] 
                ([yshift=-0.67\paperheight+1pt]current page.north west) 
                rectangle 
                ([yshift=-0.69\paperheight-1pt]current page.north east);
            \draw[LCCLightBlue, line width=2pt] ([yshift=-0.70\paperheight, xshift=1.5cm]current page.north west) -- ++(0, -5cm);
            \draw[LCCDeepBlue, line width=4pt] ([yshift=-0.70\paperheight, xshift=1.8cm]current page.north west) -- ++(0, -3.5cm);
            \node[anchor=north west, align=left] at ([xshift=2.5cm, yshift=-0.70\paperheight]current page.north west) {
                \begin{minipage}{0.7\textwidth}
                    \vspace{0.2cm}
                    {\fontsize{42}{50}\selectfont \heiti \bfseries \textcolor{LCCDeepBlue}{\lcc@title} \par}
                    \vspace{0.6cm}
                    {\Large \itshape \textcolor{LCCDeepBlue}{\lcc@subtitle} \par}
                    \vspace{1.2cm}
                    {\small \textcolor{LCCGray}{\textbf{AUTHOR} \quad \lcc@author} \par}
                    \vspace{0.2cm}
                    {\small \textcolor{LCCGray}{\textbf{CONTACT} \quad \lcc@contact} \par}
                \end{minipage}
            };
            \node[anchor=south east, inner sep=0pt] at ([xshift=-1.5cm, yshift=1.5cm]current page.south east) {
                \includegraphics[width=1.5cm]{character.png}
            };
        \end{tikzpicture}
    \end{titlepage}
}

