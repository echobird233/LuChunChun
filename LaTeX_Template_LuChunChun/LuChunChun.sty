}

%8.Section样式设计 
\newcommand{\sectionbreak}{\clearpage}
\titleformat{\section}[block]
  {\normalfont}
  {}
  {0pt}
  {\lcc@section@format}
\newcommand{\lcc@section@format}[1]{
    \if@customsec
        \begin{tikzpicture}[remember picture, overlay]
            \begin{scope}
                \clip (current page.north west) rectangle ([yshift=-0.35\paperheight]current page.north east);
                \node[anchor=north, inner sep=0pt] at (current page.north) {
                    \includegraphics[width=\paperwidth]{\lcc@sectionbg}
                };
            \end{scope}
            \fill[white, path fading=north] 
                ([yshift=-0.33\paperheight]current page.north west) 
                rectangle 
                ([yshift=-0.33\paperheight+2.5cm]current page.north east);
            \fill[white] 
                ([yshift=-0.33\paperheight+1pt]current page.north west) 
                rectangle 
                ([yshift=-0.35\paperheight-1pt]current page.north east);
            \node[anchor=south west, inner sep=0pt] at ([yshift=-0.31\paperheight]current page.north west) {
                \begin{tcolorbox}[
                    enhanced,
                    colback=white, opacityback=0.75,  
                    colframe=LCCGray, opacityframe=0.5,  
                    boxrule=1.5pt, arc=15pt, outer arc=15pt,
                    sharp corners=west, 
                    width=0.8\paperwidth, 
                    left=2.5cm, right=15pt, top=12pt, bottom=12pt 
                ]
                \Huge \heiti \bfseries \textcolor{LCCDeepBlue}{\thesection\quad #1}
                \end{tcolorbox}
            };
        \end{tikzpicture}
        \vspace*{0.28\paperheight}
        \vspace{0.4cm} 
    \else
        \Huge \heiti \bfseries \textcolor{LCCDeepBlue}{#1}
    \fi
}

